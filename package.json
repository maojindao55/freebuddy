{
  "name": "freebuddy",
  "productName": "FreeBuddy",
  "version": "0.5.7",
  "private": true,
  "description": "A WorkBuddy-style desktop AI workspace built with Electron, React, Vite, and TypeScript.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3 -w node-pty && node scripts/fix-node-pty-permissions.mjs",
    "rebuild": "electron-rebuild -f -w better-sqlite3 -w node-pty && node scripts/fix-node-pty-permissions.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json && node scripts/write-telemetry-config.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "test": "npm run build:electron && node --test --test-force-exit tests/*.mjs",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac --x64 --arm64",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:win": "npm run build && electron-builder --win --x64",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "github:preflight": "node scripts/github-preflight.mjs",
    "star-history:generate": "node scripts/generate-star-history.mjs",
    "start": "npm run build && node scripts/start-electron.mjs",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@lobehub/icons": "^5.10.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.6.0",
    "antd": "^6.4.5",
    "better-sqlite3": "^12.11.1",
    "cross-spawn": "^7.0.6",
    "electron-updater": "^6.8.9",
    "i18next": "^26.3.1",
    "lucide-react": "^0.562.0",
    "nanoid": "^5.1.11",
    "node-pty": "^1.1.0",
    "posthog-node": "^5.40.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shell-env": "^4.0.3",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^1.2.1",
    "@electron/rebuild": "^4.0.4",
    "@google/design.md": "^0.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "ajv": "^8.20.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
